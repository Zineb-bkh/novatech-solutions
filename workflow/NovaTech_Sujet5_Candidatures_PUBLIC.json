    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst score        = parseInt(body.score)        || 0;\nconst category     = body.category               || 'Non évalué';\nconst recommendation = body.recommendation       || '';\nconst feedback     = body.feedback               || '';\nconst firstName    = body.firstName              || '';\nconst lastName     = body.lastName               || '';\nconst email        = body.email                  || '';\nconst phone        = body.phone                  || 'Non renseigné';\nconst jobPosition  = body.jobPosition            || 'Non précisé';\nconst jobType      = body.jobType                || 'emploi';\nconst skills       = body.skills                 || 'Non précisées';\nconst education    = body.education              || 'Non précisée';\nconst school       = body.school                 || '';\nconst filiere      = body.filiere                || '';\nconst duration     = body.duration               || '';\nconst coverLetter  = body.coverLetter            || 'Non fournie';\nconst applicationId = body.applicationId         || 0;\nconst submittedAt  = body.submittedAt            || new Date().toISOString();\nconst cvFileName   = body.cvFileName             || '';\n\nconst isShortlisted = score >= 70;\nconst isStage       = jobType === 'stage';\n\nlet scoreColor, scoreBg, scoreBadge;\nif (score >= 80)      { scoreColor = '#15803d'; scoreBg = '#dcfce7'; scoreBadge = '🟢 Excellent'; }\nelse if (score >= 70) { scoreColor = '#1d4ed8'; scoreBg = '#dbeafe'; scoreBadge = '🔵 Bon'; }\nelse if (score >= 50) { scoreColor = '#b45309'; scoreBg = '#fef3c7'; scoreBadge = '🟡 Moyen'; }\nelse                  { scoreColor = '#b91c1c'; scoreBg = '#fee2e2'; scoreBadge = '🔴 Insuffisant'; }\n\nreturn [{\n  json: {\n    applicationId, firstName, lastName, email, phone,\n    jobPosition, jobType, skills, education,\n    school, filiere, duration, coverLetter, cvFileName,\n    submittedAt,\n    score, category, recommendation, feedback,\n    fullName: `${firstName} ${lastName}`,\n    isShortlisted,\n    isStage,\n    scoreColor, scoreBg, scoreBadge,\n    adminUrl: `http://localhost:3000/admin/applications`,\n    backendUrl: `http://localhost:5000`,\n    formattedDate: new Date(submittedAt).toLocaleDateString('fr-FR', {\n      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'\n    }),\n    formattedTime: new Date(submittedAt).toLocaleTimeString('fr-FR', {\n      hour: '2-digit', minute: '2-digit'\n    })\n  }\n}];"
      },
