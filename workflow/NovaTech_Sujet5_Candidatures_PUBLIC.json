    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst accentColor = d.isStage ? '#7c3aed' : '#4f46e5';\nconst typeLabel   = d.isStage ? 'Stage' : 'Emploi';\n\nconst html = `<!DOCTYPE html>\n<html lang=\"fr\">\n<head><meta charset=\"UTF-8\"></head>\n<body style=\"margin:0;padding:0;background:#f0f0ff;font-family:'Segoe UI',Arial,sans-serif;\">\n<div style=\"max-width:640px;margin:32px auto;border-radius:16px;overflow:hidden;box-shadow:0 4px 32px rgba(79,70,229,0.12);\">\n  <div style=\"background:linear-gradient(135deg,${accentColor},#7c3aed);padding:28px 28px;\">\n    <div style=\"display:flex;align-items:center;gap:12px;\">\n      <span style=\"font-size:2rem;\">🏆</span>\n      <div>\n        <h1 style=\"color:white;margin:0;font-size:1.3rem;font-weight:800;\">Nouveau candidat shortlisté !</h1>\n        <p style=\"color:rgba(255,255,255,0.8);margin:4px 0 0;font-size:0.8rem;\">NovaTech — Système de gestion des candidatures</p>\n      </div>\n    </div>\n  </div>\n\n  <div style=\"padding:28px;background:white;\">\n\n    <table style=\"width:100%;border-collapse:collapse;margin-bottom:20px;\">\n      <tr>\n        <td style=\"padding:10px 14px;background:#f8f7ff;border-radius:10px 10px 0 0;border-bottom:1px solid #e5e7eb;\">\n          <span style=\"font-size:0.7rem;font-weight:700;color:${accentColor};text-transform:uppercase;letter-spacing:1px;\">Candidat</span><br>\n          <strong style=\"color:#111827;font-size:1rem;\">${d.fullName}</strong>\n        </td>\n        <td style=\"padding:10px 14px;background:#f8f7ff;border-radius:10px 10px 0 0;border-bottom:1px solid #e5e7eb;\">\n          <span style=\"font-size:0.7rem;font-weight:700;color:${accentColor};text-transform:uppercase;letter-spacing:1px;\">Type</span><br>\n          <strong style=\"color:#111827;\">${typeLabel}</strong>\n        </td>\n      </tr>\n      <tr>\n        <td style=\"padding:10px 14px;border-bottom:1px solid #e5e7eb;\">\n          <span style=\"font-size:0.7rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:1px;\">Email</span><br>\n          <a href=\"mailto:${d.email}\" style=\"color:${accentColor};\">${d.email}</a>\n        </td>\n        <td style=\"padding:10px 14px;border-bottom:1px solid #e5e7eb;\">\n          <span style=\"font-size:0.7rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:1px;\">Téléphone</span><br>\n          <span style=\"color:#374151;\">${d.phone}</span>\n        </td>\n      </tr>\n      <tr>\n        <td style=\"padding:10px 14px;border-bottom:1px solid #e5e7eb;\">\n          <span style=\"font-size:0.7rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:1px;\">Poste</span><br>\n          <strong style=\"color:#374151;\">${d.jobPosition}</strong>\n        </td>\n        <td style=\"padding:10px 14px;border-bottom:1px solid #e5e7eb;\">\n          <span style=\"font-size:0.7rem;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:1px;\">Reçue le</span><br>\n          <span style=\"color:#374151;\">${d.formattedDate}</span>\n        </td>\n      </tr>\n    </table>\n\n    <div style=\"background:${d.scoreBg};border-radius:14px;padding:20px;margin:20px 0;display:flex;align-items:center;gap:20px;\">\n      <div style=\"text-align:center;min-width:80px;\">\n        <div style=\"font-size:2.5rem;font-weight:900;color:${d.scoreColor};letter-spacing:-1px;\">${d.score}</div>\n        <div style=\"font-size:0.65rem;font-weight:700;color:${d.scoreColor};text-transform:uppercase;letter-spacing:1px;\">/ 100</div>\n      </div>\n      <div style=\"flex:1;border-left:2px solid ${d.scoreColor}33;padding-left:18px;\">\n        <div style=\"font-weight:700;color:${d.scoreColor};font-size:0.9rem;\">${d.scoreBadge}</div>\n        <div style=\"color:#4b5563;font-size:0.8rem;margin-top:4px;\">${d.recommendation}</div>\n      </div>\n    </div>\n\n    <div style=\"text-align:center;margin-top:24px;\">\n      <a href=\"${d.adminUrl}\" style=\"display:inline-block;background:linear-gradient(135deg,${accentColor},#7c3aed);color:white;padding:14px 36px;border-radius:12px;text-decoration:none;font-weight:700;font-size:0.9rem;\"\n      >Voir dans l'admin NovaTech →</a>\n    </div>\n  </div>\n\n  <div style=\"background:#f8f7ff;padding:16px;text-align:center;border-top:1px solid #e5e7eb;\">\n    <p style=\"color:#9ca3af;font-size:0.72rem;margin:0;\">NovaTech Solutions — Workflow automatique Sujet 5 PFE</p>\n  </div>\n</div>\n</body></html>`;\n\nreturn [{ json: { ...d, adminEmailHtml: html } }];"
      },
