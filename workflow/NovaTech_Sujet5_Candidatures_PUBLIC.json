      "id": "a6cf4692-fae8-4dae-933d-06cfbd0b9bb6",
      "name": "Score ≥ 70 ? (Shortlist)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [512, 192]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst accentColor = d.isStage ? '#7c3aed' : '#4f46e5';\nconst typeLabel   = d.isStage ? 'stage' : \"d'emploi\";\n\nconst html = `<!DOCTYPE html>\n<html lang=\"fr\">\n<head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"></head>\n<body style=\"margin:0;padding:0;background:#f0f0ff;font-family:'Segoe UI',Arial,sans-serif;\">\n<div style=\"max-width:600px;margin:40px auto;border-radius:20px;overflow:hidden;box-shadow:0 8px 48px rgba(79,70,229,0.15);\">\n\n  <div style=\"background:linear-gradient(135deg,${accentColor},#7c3aed);padding:40px 32px;text-align:center;\">\n    <div style=\"font-size:3rem;margin-bottom:12px;\">🎉</div>\n    <h1 style=\"color:white;margin:0;font-size:1.8rem;font-weight:900;letter-spacing:-0.5px;\">NovaTech Solutions</h1>\n    <p style=\"color:rgba(255,255,255,0.85);margin:8px 0 0;font-size:0.9rem;\">Vous êtes sélectionné(e) pour un entretien !</p>\n  </div>\n\n  <div style=\"padding:36px 32px;background:#fff;\">\n    <p style=\"color:#374151;font-size:1rem;margin:0 0 16px;\">Bonjour <strong>${d.firstName}</strong>,</p>\n\n    <p style=\"color:#374151;line-height:1.7;margin:0 0 20px;\">\n      Excellente nouvelle ! Votre candidature ${typeLabel} pour le poste de\n      <strong style=\"color:${accentColor};\">${d.jobPosition}</strong>\n      a retenu toute notre attention. Vous faites partie des candidats <strong>shortlistés</strong> par notre système d'analyse IA.\n    </p>\n\n    <div style=\"background:${d.scoreBg};border-radius:16px;padding:24px;margin:24px 0;text-align:center;border:2px solid ${d.scoreColor}33;\">\n      <div style=\"font-size:3rem;font-weight:900;color:${d.scoreColor};letter-spacing:-2px;\">${d.score}<span style=\"font-size:1.2rem;opacity:0.6;\">/100</span></div>\n      <div style=\"font-size:0.75rem;font-weight:700;color:${d.scoreColor};text-transform:uppercase;letter-spacing:2px;margin:6px 0;\">${d.category}</div>\n      ${d.feedback ? `<p style=\"margin:14px 0 0;font-size:0.875rem;color:#374151;font-style:italic;border-top:1px solid ${d.scoreColor}22;padding-top:12px;line-height:1.6;\">&ldquo;${d.feedback}&rdquo;</p>` : ''}\n    </div>\n\n    <div style=\"background:#f0fdf4;border-radius:12px;padding:20px;border-left:4px solid #22c55e;margin-bottom:24px;\">\n      <p style=\"color:#15803d;font-weight:700;font-size:0.85rem;text-transform:uppercase;letter-spacing:1px;margin:0 0 10px;\">✅ Prochaines étapes</p>\n      <p style=\"color:#166534;font-size:0.875rem;margin:4px 0;\">→ Notre équipe vous contactera dans les <strong>48 heures</strong></p>\n      <p style=\"color:#166534;font-size:0.875rem;margin:4px 0;\">→ Préparez vos projets et exemples de code</p>\n      <p style=\"color:#166534;font-size:0.875rem;margin:4px 0;\">→ L'entretien sera technique + RH (45 min)</p>\n    </div>\n\n    <div style=\"text-align:center;margin-top:24px;\">\n      <p style=\"color:#6b7280;font-size:0.875rem;\">Des questions ? Répondez directement à cet email.</p>\n    </div>\n  </div>\n\n  <div style=\"background:#f8f7ff;padding:20px 32px;text-align:center;border-top:1px solid #e5e7eb;\">\n    <p style=\"color:#4f46e5;font-weight:700;font-size:0.875rem;margin:0;\">NovaTech Solutions</p>\n    <p style=\"color:#9ca3af;font-size:0.75rem;margin:6px 0 0;\">Transforming Digital Vision Into Reality</p>\n  </div>\n</div>\n</body></html>`;\n\nreturn [{ json: { ...d, emailHtml: html, emailSubject: `🎉 Sélectionné(e) pour un entretien — ${d.jobPosition} | NovaTech` } }];"
      },
      "id": "8c729b4d-a593-40ae-8822-84f3e529ea63",
      "name": "Générer HTML — Email Acceptation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [784, 0]
    },
    {
      "parameters": {
        "jsCode": "const d = $input.first().json;\nconst accentColor = d.isStage ? '#7c3aed' : '#4f46e5';\nconst typeLabel   = d.isStage ? 'de stage' : \"d'emploi\";\n\nconst html = `<!DOCTYPE html>\n<html lang=\"fr\">\n<head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"></head>\n<body style=\"margin:0;padding:0;background:#f4f4f8;font-family:'Segoe UI',Arial,sans-serif;\">\n<div style=\"max-width:600px;margin:40px auto;border-radius:20px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);\">\n\n  <div style=\"background:linear-gradient(135deg,#475569,#334155);padding:36px 32px;text-align:center;\">\n    <div style=\"font-size:2.5rem;margin-bottom:10px;\">📋</div>\n    <h1 style=\"color:white;margin:0;font-size:1.6rem;font-weight:800;\">NovaTech Solutions</h1>\n    <p style=\"color:rgba(255,255,255,0.75);margin:6px 0 0;font-size:0.85rem;\">Réponse à votre candidature ${typeLabel}</p>\n  </div>\n\n  <div style=\"padding:36px 32px;background:#fff;\">\n    <p style=\"color:#374151;font-size:1rem;margin:0 0 16px;\">Bonjour <strong>${d.firstName}</strong>,</p>\n\n    <p style=\"color:#4b5563;line-height:1.7;margin:0 0 20px;\">\n      Nous avons examiné avec soin votre candidature ${typeLabel} pour le poste de\n      <strong style=\"color:${accentColor};\">${d.jobPosition}</strong>.\n      Après analyse approfondie de votre profil, nous ne sommes malheureusement pas en mesure\n      de donner suite à votre candidature pour cette offre à ce stade.\n    </p>\n\n    ${d.feedback ? `\n    <div style=\"background:#f8fafc;border-radius:12px;padding:20px;margin:20px 0;border-left:4px solid #94a3b8;\">\n      <p style=\"color:#64748b;font-weight:700;font-size:0.8rem;text-transform:uppercase;letter-spacing:1px;margin:0 0 8px;\">💡 Retour personnalisé</p>\n      <p style=\"color:#475569;font-size:0.875rem;line-height:1.6;font-style:italic;margin:0;\">&ldquo;${d.feedback}&rdquo;</p>\n    </div>` : ''}\n\n    <div style=\"background:#eff6ff;border-radius:12px;padding:20px;border-left:4px solid ${accentColor};margin-bottom:24px;\">\n      <p style=\"color:#1d4ed8;font-weight:700;font-size:0.85rem;margin:0 0 10px;\">🚀 Continuez à progresser</p>\n      <p style=\"color:#1e40af;font-size:0.875rem;margin:4px 0;\">→ Restez à l'affût de nos futures offres sur notre site</p>\n      <p style=\"color:#1e40af;font-size:0.875rem;margin:4px 0;\">→ Enrichissez votre profil GitHub avec des projets concrets</p>\n      <p style=\"color:#1e40af;font-size:0.875rem;margin:4px 0;\">→ N'hésitez pas à repostuler dans 6 mois</p>\n    </div>\n\n    <p style=\"color:#9ca3af;font-size:0.8rem;text-align:center;\">\n      Nous vous souhaitons plein succès dans votre recherche.\n    </p>\n  </div>\n\n  <div style=\"background:#f8f7ff;padding:20px 32px;text-align:center;border-top:1px solid #e5e7eb;\">\n    <p style=\"color:#4f46e5;font-weight:700;font-size:0.875rem;margin:0;\">NovaTech Solutions</p>\n    <p style=\"color:#9ca3af;font-size:0.75rem;margin:6px 0 0;\">Transforming Digital Vision Into Reality</p>\n  </div>\n</div>\n</body></html>`;\n\nreturn [{ json: { ...d, emailHtml: html, emailSubject: `NovaTech Solutions — Réponse à votre candidature pour ${d.jobPosition}` } }];"
      },
      "id": "2e05919a-c9d2-4a5e-bcc9-935819819786",
      "name": "Générer HTML — Email Refus",
